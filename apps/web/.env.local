#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY_LOCAL="039c133af0b4b3f240fe3681944544bb9ff17ed7e1fafdbb8e09a6b70fab9c7208"

# =============================================================================
# URL 設定
# =============================================================================
# NEXT_PUBLIC_APP_URL: ブラウザにも公開される（OAuth redirect_uri の組み立てに使用）
# API_URL: サーバー側 fetch のみで使用（apiClient / Route Handler が Express を呼ぶ先）
NEXT_PUBLIC_APP_URL="encrypted:BLOtdliKmyL0XARHdWI+5sYB0h4QcMxhzoTm2OFz0ytwg9XNFmxUiu9xBa+ogIOs9/rOPDm8xqaqVA7P9MB5dEKd2tP74io9PaoHfdxmjsilmbGldKnXYEzytpxqROpkrt1ZjnO1IUtLBLTwvYuzp+3wYMbeTQ=="
API_URL="encrypted:BMQfbns3gJIss90bMRryOvi9ou6po7bTSQ+I9yUeoMHgn3ttq6DmdI3qSNcm017xSD7HxE4tb+IlwybZiWDrZ75vSoYn8ENxwHn4I9wqBKCQS8vh9OOUxah0r2TyLnNaSp+poaIGYoUzSIX/Th6SlHbnElyIQA=="

# =============================================================================
