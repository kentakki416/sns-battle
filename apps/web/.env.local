# client_secret は API 側のみで使うため Web には保持しない（最小権限）
GOOGLE_CLIENT_ID="encrypted:BFR9X/bgZhxD5HjyzLmEPL7+0Q6vFBdZxXaCC4fv9w8V48SR/Wo1qepl7UMTCNkepd9LvaSxzW3ispPBx3ffwFHtO4OY+GKcBGt5b2e/ihBDtksz4+e/L3iM3vzot5u3H3GMBKcrnCjNQSv3N+Y9yiG0/5OhsK8wsos9Xz6Phadl8aKea4B9B56dMR648CTtu79g9N2kSDdrYh+fXLc7s4NmEcJNWi0XdA=="
